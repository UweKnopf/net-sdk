<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net8.0;net9.0;net10.0</TargetFrameworks>
    <RootNamespace>net_sdk</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>TCGDexSDK</PackageId>
    <Version>1.0.0</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Authors>Uwe Knopf</Authors>
    <Description>TCGDex SDK for .NET</Description>
    <PackageTags>TCGDex, SDK, .NET, Pokomon</PackageTags>
    <RepositoryUrl>https://github.com/UweKnopf/TCGDexNetSDK</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <Folder Include="src/" />
    <Folder Include="src/models/" />
    <Folder Include="src/models/subs/" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="RestSharp" Version="113.1.0" />
  </ItemGroup>

</Project>
